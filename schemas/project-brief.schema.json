{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-control/project-brief.schema.json",
  "title": "Project Brief Source File",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "projectName",
    "oneLineDefinition",
    "projectType",
    "finalGoal",
    "targetOutcome",
    "audienceExperience",
    "scopeIn",
    "scopeOut",
    "overallCompletion"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "project_brief" },
    "projectName": { "type": "string" },
    "scanMeta": { "type": "object" },
    "oneLineDefinition": { "type": "object" },
    "projectType": { "type": "object" },
    "finalGoal": { "type": "object" },
    "targetOutcome": { "type": "object" },
    "audienceExperience": { "type": "object" },
    "scopeIn": { "type": "object" },
    "scopeOut": { "type": "object" },
    "overallCompletion": { "type": "object" },
    "knownFacts": { "type": "array" },
    "declaredItems": { "type": "array" },
    "needsConfirmation": { "type": "array" }
  },
  "additionalProperties": true
}
